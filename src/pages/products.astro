---
import Layout from "../layouts/Layout.astro";

const icon = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;

const products = [
  {
    icon: icon(
      '<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>'
    ),
    title: "Azkar",
    status: "Coming Soon",
    description:
      "A beautifully simple iOS app for daily remembrance—thoughtfully designed to fit naturally into your day. Our first application, currently in development.",
  },
  {
    icon: icon(
      '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>'
    ),
    title: "Productivity Apps",
    status: "In Planning",
    description:
      "A future family of focused productivity tools that help you organize, plan, and accomplish more—without the clutter.",
  },
  {
    icon: icon(
      '<path d="M12 2a7 7 0 0 0-4 12.7V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.3A7 7 0 0 0 12 2Z"/><path d="M9 21h6"/>'
    ),
    title: "AI Tools",
    status: "In Planning",
    description:
      "Practical AI-powered tools that make everyday tasks smarter and simpler—useful intelligence, not novelty.",
  },
];
---

<Layout
  title="Products"
  description="Our first products are currently in development, starting with Azkar for iOS—with focused productivity apps and practical AI tools to follow."
>
  <section class="section products-intro">
    <div class="container text-center" data-animate>
      <span class="eyebrow">Products</span>
      <h1>Our first products are currently in development</h1>
      <p class="products-intro__body">
        We're building our first generation of applications with the same care we'd want in the
        software we use every day. Here's a look at what's coming.
      </p>
    </div>
  </section>

  <section class="section section--subtle">
    <div class="container">
      <div class="grid grid--3 products-grid" data-animate-group>
        {products.map((product) => (
          <div class="card product">
            <div class="card-icon" set:html={product.icon} />
            <div class="product__heading">
              <h2>{product.title}</h2>
              <span class="product__status">{product.status}</span>
            </div>
            <p>{product.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center products-cta" data-animate>
        <p>Want to be the first to know when we launch?</p>
        <a href="/contact" class="btn btn--primary">Get in Touch</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .products-intro {
    padding-block: 96px 64px;
  }

  .products-intro h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    max-width: 720px;
    margin: 0 auto 16px;
  }

  .products-intro__body {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1.1rem;
  }

  .product__heading {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .product__heading h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  .product__status {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid var(--color-accent-tint-strong);
    border-radius: var(--radius-full);
    padding: 3px 10px;
    white-space: nowrap;
  }

  .products-cta {
    margin-top: 56px;
  }

  .products-cta p {
    margin: 0 0 20px;
    font-size: 1.05rem;
  }
</style>
