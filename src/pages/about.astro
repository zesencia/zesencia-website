---
import Layout from "../layouts/Layout.astro";

const icon = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;

const arrowIcon = icon('<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>');

const focusAreas = [
  {
    icon: icon(
      '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>'
    ),
    title: "Mobile Applications",
    description: "Native iOS experiences built with care for detail and everyday usability.",
    features: ["Native iOS development", "Everyday usability", "Careful attention to detail"],
  },
  {
    icon: icon('<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>'),
    title: "Cloud Services",
    description: "Scalable backend platforms and infrastructure that stay reliable as you grow.",
    features: ["Scalable infrastructure", "Reliable as you grow", "Modern backend platforms"],
  },
  {
    icon: icon(
      '<path d="M12 2a7 7 0 0 0-4 12.7V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.3A7 7 0 0 0 12 2Z"/><path d="M9 21h6"/>'
    ),
    title: "AI Solutions",
    description: "Practical applications of AI that make products smarter without adding friction.",
    features: ["Practical AI integration", "Smarter, not more complex", "Human-centered design"],
  },
  {
    icon: icon(
      '<rect x="2" y="6" width="20" height="14" rx="2"/><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>'
    ),
    title: "Enterprise Applications",
    description: "Custom Java applications and business web applications built for enterprise workflows.",
    features: ["Java application development", "Business web applications", "Built for enterprise workflows"],
  },
];
---

<Layout
  title="About"
  description="Zesencia Technologies creates thoughtfully designed software that combines elegant user experiences with dependable engineering."
>
  <section class="section about-intro">
    <div class="container" data-animate>
      <span class="eyebrow">About</span>
      <h1>Building software that earns your trust</h1>
      <p class="about-intro__lead">
        Zesencia Technologies creates thoughtfully designed software that combines elegant user
        experiences with dependable engineering. Our mission is to build products that solve real
        problems through simplicity, innovation, and quality.
      </p>
      <div class="about-story">
        <h2>Why Zesencia</h2>
        <p>
          Zesencia was founded on a simple belief: the best software feels effortless. Too many
          products trade clarity for feature lists and long-term quality for short-term speed. We
          take the opposite path—fewer things, built carefully, supported properly.
        </p>
        <p>
          We're an independent software studio based in Texas, operated by Sublime Trade LLC. As
          an early-stage company, we're deliberately small: every project gets direct attention
          from the people who actually design and build it. You can always reach us at
          {" "}<a href="mailto:hello@zesencia.com">hello@zesencia.com</a>.
        </p>
      </div>

      <dl class="about-pillars">
        <div class="about-pillars__item">
          <dt>Our Mission</dt>
          <dd>
            To build products that solve real problems through simplicity, innovation, and
            quality—software that makes everyday life genuinely easier.
          </dd>
        </div>
        <div class="about-pillars__item">
          <dt>Engineering Philosophy</dt>
          <dd>
            We engineer for the long term: clean architecture, maintainable code, and technology
            choices made for durability rather than trends.
          </dd>
        </div>
        <div class="about-pillars__item">
          <dt>Quality Commitment</dt>
          <dd>
            Everything we ship is tested, polished, and held to a high standard. We would rather
            release fewer things done well than many things done halfway.
          </dd>
        </div>
        <div class="about-pillars__item">
          <dt>Customers First</dt>
          <dd>
            From the first conversation to long after launch, we listen, communicate clearly, and
            treat every customer's goals as our own.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section section--subtle">
    <div class="container">
      <h2 data-animate>Areas of Focus</h2>
      <div class="grid grid--2 focus-grid" data-animate-group>
        {focusAreas.map((area) => (
          <div class="card">
            <div class="card-icon" set:html={area.icon} />
            <h3>{area.title}</h3>
            <p>{area.description}</p>
            <ul class="card__features">
              {area.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a href="/contact" class="card__link">
              Learn More
              <Fragment set:html={arrowIcon} />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-intro {
    padding-block: 96px 64px;
  }

  .about-intro h1 {
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    max-width: 700px;
    margin: 0 0 20px;
  }

  .about-intro__lead {
    font-size: 1.1rem;
    max-width: 640px;
  }

  .about-story {
    margin-top: 48px;
    max-width: 640px;
  }

  .about-story h2 {
    font-size: 1.4rem;
    margin: 0 0 16px;
  }

  .about-story p {
    margin: 0 0 16px;
  }

  .about-story a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .about-story a:hover {
    text-decoration: underline;
  }

  .about-pillars {
    margin: 48px 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 40px;
    max-width: 880px;
  }

  .about-pillars__item dt {
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 6px;
  }

  .about-pillars__item dd {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 720px) {
    .about-pillars {
      grid-template-columns: 1fr;
    }
  }

  .focus-grid {
    margin-top: 32px;
  }
</style>
