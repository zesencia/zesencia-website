---
import Layout from "../layouts/Layout.astro";

const icon = (path: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;

const arrowIcon = icon('<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>');

const whatWeDo = [
  {
    icon: icon(
      '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>'
    ),
    title: "Mobile Apps",
    description: "Beautiful, intuitive iOS applications designed for everyday use.",
    features: ["Native iOS development", "Intuitive user experience", "Built for everyday use"],
  },
  {
    icon: icon(
      '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>'
    ),
    title: "Cloud Solutions",
    description:
      "Reliable cloud services and modern backend platforms built for performance and scalability.",
    features: ["Scalable architecture", "Built for reliability", "Performance-focused"],
  },
  {
    icon: icon(
      '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>'
    ),
    title: "Custom Software",
    description:
      "Tailored software solutions engineered with a focus on quality, maintainability, and long-term value.",
    features: ["Tailored to your needs", "Quality-first engineering", "Built for the long term"],
  },
];

const principles = [
  {
    icon: icon(
      '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>'
    ),
    title: "Simplicity",
    description: "We believe software should feel effortless.",
  },
  {
    icon: icon(
      '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>'
    ),
    title: "Reliability",
    description: "Every product is built with quality and long-term support in mind.",
  },
  {
    icon: icon(
      '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.287 1.288L3 12l5.8 1.9a2 2 0 0 1 1.288 1.287L12 21l1.9-5.8a2 2 0 0 1 1.287-1.288L21 12l-5.8-1.9a2 2 0 0 1-1.288-1.287Z"/>'
    ),
    title: "Craftsmanship",
    description: "Attention to detail matters—from user experience to code quality.",
  },
];

const process = [
  {
    title: "Discover",
    description: "We start by understanding the problem, your goals, and who you're building for.",
  },
  {
    title: "Design",
    description: "We shape the experience first—clear flows, clean interfaces, no unnecessary complexity.",
  },
  {
    title: "Build",
    description: "We engineer with quality and maintainability in mind, keeping you involved at every step.",
  },
  {
    title: "Support",
    description: "Launch is the beginning. We stay engaged to refine, improve, and support what we ship.",
  },
];
---

<Layout title="Zesencia Technologies">
  <section class="section hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container hero__inner" data-animate>
      <h1>Software with Purpose.<br />Technology with Elegance.</h1>
      <p class="hero__subtext">
        We design and build thoughtfully crafted mobile applications, cloud software, and
        intelligent digital experiences that simplify everyday life and help people accomplish
        more.
      </p>
      <div class="stack text-center hero__actions">
        <a href="/products" class="btn btn--primary">Explore Products</a>
        <a href="/contact" class="btn btn--secondary">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="section section--subtle">
    <div class="container">
      <div class="text-center" data-animate>
        <span class="eyebrow">What We Do</span>
        <h2>Focused on a few things, done well</h2>
      </div>
      <div class="grid grid--3 what-we-do" data-animate-group>
        {whatWeDo.map((item) => (
          <div class="card">
            <div class="card-icon" set:html={item.icon} />
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <ul class="card__features">
              {item.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a href="/contact" class="card__link">
              Learn More
              <Fragment set:html={arrowIcon} />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tint">
    <div class="container">
      <div class="text-center" data-animate>
        <span class="eyebrow">Our Principles</span>
        <h2>What guides how we build</h2>
      </div>
      <div class="grid grid--3 principles" data-animate-group>
        {principles.map((principle) => (
          <div class="card principle">
            <div class="card-icon" set:html={principle.icon} />
            <h3>{principle.title}</h3>
            <p>{principle.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" data-animate>
        <span class="eyebrow">How We Work</span>
        <h2>From idea to launch, step by step</h2>
      </div>
      <ol class="process" data-animate-group>
        {process.map((step, index) => (
          <li class="process__step">
            <span class="process__number">{index + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta" data-animate>
        <h2>Have an idea you'd like to bring to life?</h2>
        <p>Let's build something great together.</p>
        <a href="/contact" class="btn btn--primary">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding-block: 88px 96px;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 640px;
    background: radial-gradient(
        520px circle at 18% 20%,
        rgba(37, 99, 235, 0.14),
        transparent 60%
      ),
      radial-gradient(480px circle at 82% 10%, rgba(37, 99, 235, 0.1), transparent 55%),
      radial-gradient(600px circle at 50% 90%, rgba(37, 99, 235, 0.06), transparent 60%);
    pointer-events: none;
    z-index: -1;
  }

  .hero__inner {
    max-width: 760px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    margin: 0 0 28px;
  }

  .hero__subtext {
    font-size: 1.15rem;
    margin: 0 auto 36px;
    max-width: 580px;
  }

  .hero__actions {
    justify-content: center;
  }

  .what-we-do {
    margin-top: 48px;
  }

  .principles {
    margin-top: 48px;
  }

  .principle {
    text-align: center;
  }

  .principle .card-icon {
    margin-inline: auto;
  }

  .process {
    list-style: none;
    margin: 48px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .process__step {
    position: relative;
    padding: 28px 24px 0;
    border-top: 2px solid var(--color-border);
  }

  .process__number {
    position: absolute;
    top: -17px;
    left: 24px;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background: var(--color-accent-tint);
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.9rem;
    border: 2px solid var(--color-border);
  }

  .process__step h3 {
    margin: 0 0 8px;
    font-size: 1.1rem;
  }

  .process__step p {
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .process {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .cta {
    text-align: center;
    padding: 64px 40px;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--color-bg-subtle), #eef2ff);
    border: 1px solid var(--color-border);
  }

  .cta h2 {
    margin: 0 0 12px;
  }

  .cta p {
    margin: 0 0 28px;
  }
</style>
