---
import Layout from "../layouts/Layout.astro";

const whatWeDo = [
  {
    icon: "📱",
    title: "Mobile Apps",
    description: "Beautiful, intuitive iOS applications designed for everyday use.",
  },
  {
    icon: "☁️",
    title: "Cloud Solutions",
    description:
      "Reliable cloud services and modern backend platforms built for performance and scalability.",
  },
  {
    icon: "💡",
    title: "Custom Software",
    description:
      "Tailored software solutions engineered with a focus on quality, maintainability, and long-term value.",
  },
];

const principles = [
  {
    title: "Simplicity",
    description: "We believe software should feel effortless.",
  },
  {
    title: "Reliability",
    description: "Every product is built with quality and long-term support in mind.",
  },
  {
    title: "Craftsmanship",
    description: "Attention to detail matters—from user experience to code quality.",
  },
];
---

<Layout title="Zesencia Technologies">
  <section class="section hero">
    <div class="container hero__inner">
      <h1>Software with Purpose.<br />Technology with Elegance.</h1>
      <p class="hero__subtext">
        We design and build thoughtfully crafted mobile applications, cloud software, and
        intelligent digital experiences that simplify everyday life and help people accomplish
        more.
      </p>
      <div class="stack text-center hero__actions">
        <a href="/products" class="btn btn--primary">Explore Products</a>
        <a href="/contact" class="btn btn--secondary">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="section section--subtle">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">What We Do</span>
        <h2>Focused on a few things, done well</h2>
      </div>
      <div class="grid grid--3 what-we-do">
        {whatWeDo.map((item) => (
          <div class="card">
            <div class="card-icon">{item.icon}</div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Our Principles</span>
        <h2>What guides how we build</h2>
      </div>
      <div class="grid grid--3 principles">
        {principles.map((principle) => (
          <div class="principle">
            <h3>{principle.title}</h3>
            <p>{principle.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="container text-center">
      <h2>Have an idea you'd like to bring to life?</h2>
      <p>Let's build something great together.</p>
      <a href="/contact" class="btn btn--primary">Contact Us</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: 120px 96px;
  }

  .hero__inner {
    max-width: 760px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 20px;
  }

  .hero__subtext {
    font-size: 1.15rem;
    margin: 0 auto 36px;
    max-width: 620px;
  }

  .hero__actions {
    justify-content: center;
  }

  .what-we-do {
    margin-top: 48px;
  }

  .principles {
    margin-top: 48px;
    text-align: center;
  }

  .principle h3 {
    margin-bottom: 8px;
  }

  .cta h2 {
    margin: 0 0 12px;
  }

  .cta p {
    margin: 0 0 28px;
  }
</style>
