---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img
        src="/logo-horizontal.png"
        alt="Zesencia Technologies"
        class="footer__logo"
        width="434"
        height="129"
        loading="lazy"
        decoding="async"
      />
      <p class="footer__tagline">Software with Purpose. Technology with Elegance.</p>
      <p class="footer__legal">A software brand operated by Sublime Trade LLC.</p>
    </div>

    <nav class="footer__links" aria-label="Footer">
      <a href="/products">Products</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
    </nav>

    <div class="footer__meta">
      <p><a href="mailto:hello@zesencia.com">hello@zesencia.com</a></p>
      <p>Frisco, Texas, USA</p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p>&copy; {year} Zesencia Technologies. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
  }

  .footer__inner {
    padding-block: 56px;
    display: grid;
    gap: 40px;
    grid-template-columns: 1.8fr 1fr 1fr;
  }

  .footer__logo {
    height: 35px;
    width: auto;
    display: block;
    margin-bottom: 12px;
  }

  .footer__tagline {
    margin: 0 0 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__links a {
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__meta p {
    margin: 0 0 8px;
    font-size: 0.9rem;
  }

  .footer__meta a {
    text-decoration: none;
    color: var(--color-text-secondary);
  }

  .footer__meta a:hover {
    color: var(--color-accent);
  }

  .footer__legal {
    margin: 0;
    color: #64748b;
    font-size: 0.8rem;
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 20px;
  }

  .footer__bottom p {
    margin: 0;
    font-size: 0.85rem;
    color: #64748b;
  }

  @media (max-width: 720px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
