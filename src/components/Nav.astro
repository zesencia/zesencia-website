---
const navLinks = [
  { href: "/products", label: "Products" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === currentPath || (href !== "/" && currentPath.startsWith(href));
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand">
      <img src="/logo-horizontal.png" alt="Zesencia Technologies" class="nav__logo" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {navLinks.map((link) => (
        <a href={link.href} class={isActive(link.href) ? "is-active" : ""}>{link.label}</a>
      ))}
    </nav>

    <a href="/contact" class="btn btn--primary nav__cta">Get in Touch</a>
  </div>
</header>

<style>
  .nav {
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 20px rgba(15, 23, 42, 0.05);
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 20px;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav__logo {
    height: 43px;
    width: auto;
    display: block;
  }

  .nav__links {
    display: flex;
    gap: 28px;
    flex: 1;
    justify-content: center;
  }

  .nav__links a {
    position: relative;
    text-decoration: none;
    color: var(--color-text-secondary);
    font-weight: 600;
    font-size: 0.95rem;
    padding-block: 4px;
  }

  .nav__links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .nav__links a:hover {
    color: var(--color-accent);
  }

  .nav__links a:hover::after {
    transform: scaleX(1);
  }

  .nav__links a.is-active {
    color: var(--color-accent);
  }

  .nav__links a.is-active::after {
    transform: scaleX(1);
  }

  .nav__cta {
    white-space: nowrap;
    padding: 10px 20px;
    font-size: 0.9rem;
  }

  @media (max-width: 720px) {
    .nav__links {
      display: none;
    }
  }
</style>
